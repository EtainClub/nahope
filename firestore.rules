rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles: anyone can read, only authenticated users can write
    match /users/{walletAddress} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Community posts: anyone can read, authenticated users can create/update
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }
  }
}
