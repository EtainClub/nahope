rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Rules for the movie intro folder
    match /intro/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Default fallback rules for other folders
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
